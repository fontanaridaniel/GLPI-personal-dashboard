# WS urls
GLPI_API_BASE_URL=https://your-glpi-domain.example/api.php
GLPI_AUTH_URL=https://your-glpi-domain.example/api.php/token
GLPI_WEB_BASE_URL=https://your-glpi-domain.example

# WS Authentication
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
USERNAME=your_username_here

# Target User
USER_ID=123

# Automatic dashboard refresh interval
AUTO_REFRESH_SECONDS=120

# Retentio for the recent updates card
UPDATE_RETENTION_HOURS=24

# Relative and absolute path for the local databases
NOTES_DB_PATH=db/notes-db.json
UPDATES_DB_PATH=db/updates-db.json
UPDATES_SNAPSHOT_PATH=db/updates-snapshot.json

# Simultaneous task API requests
TASK_CONCURRENCY=6

# Pagination size
PAGE_SIZE=100

# The level of Log printed (INFO, WARN, ERROR)
LOG_LEVEL=INFO

# The port where to host the WS
HOST_PORT=0 